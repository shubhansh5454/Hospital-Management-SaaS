generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  uid           String         @unique(map: "users_uid_unique")
  email         String         @unique
  name          String
  password      String?
  role          String         @default("patient")
  refreshToken  String?        @map("refresh_token")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  clinicId      Int?           @map("clinic_id")
  appointments  Appointment[]
  doctorProfile DoctorProfile?
  emrRecords    EmrRecord[]
  invoices      Invoice[]
  queueTokens   QueueToken[]
  notifications Notification[]
  clinic        Clinic?        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  customRoleId  Int?           @map("custom_role_id")
  customRole    CustomRole?    @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  userPermissions UserPermission[]
  auditLogs       AuditLog[]
  uploadedFiles   ClinicFile[]
  tenantId      Int?           @map("tenant_id")
  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cdsSuggestions AICdsSuggestion[] @relation("DoctorCds")
  imagingOrders    ImagingOrder[]   @relation("DoctorImagingOrders")
  radiologyReports RadiologyReport[] @relation("DoctorRadiologyReports")

  @@index([clinicId])
  @@index([role])
  @@map("users")
}

model Patient {
  id             Int           @id @default(autoincrement())
  name           String
  email          String
  phone          String
  dob            String
  gender         String
  bloodGroup     String?       @map("blood_group")
  address        String?
  medicalHistory String?       @map("medical_history")
  allergies      String?       @map("allergies")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  clinicId       Int?          @map("clinic_id")
  appointments   Appointment[]
  emrRecords     EmrRecord[]
  invoices       Invoice[]
  medicineSales  MedicineSale[]
  labOrders      LabOrder[]
  queueTokens    QueueToken[]
  notifications  Notification[]
  clinic         Clinic?       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  files          ClinicFile[]
  cdsSuggestions AICdsSuggestion[]
  imagingOrders    ImagingOrder[]
  radiologyReports RadiologyReport[]

  @@index([clinicId])
  @@index([email])
  @@map("patients")
}

model Appointment {
  id        Int      @id @default(autoincrement())
  patientId Int      @map("patient_id")
  doctorId  Int      @map("doctor_id")
  date      String
  time      String
  status    String   @default("scheduled")
  reason    String
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  clinicId  Int?     @map("clinic_id")
  doctor    User     @relation(fields: [doctorId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "appointments_doctor_id_users_id_fk")
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "appointments_patient_id_patients_id_fk")
  queueToken QueueToken?
  clinic    Clinic?  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([patientId])
  @@index([doctorId])
  @@index([date])
  @@map("appointments")
}

model DoctorProfile {
  id             Int                  @id @default(autoincrement())
  userId         Int                  @unique @map("user_id")
  specialization String
  biography      String?
  experienceYrs  Int                  @default(0) @map("experience_yrs")
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamp(6)
  
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  schedules      DoctorAvailability[]
  leaves         DoctorLeave[]

  @@map("doctor_profiles")
}

model DoctorAvailability {
  id              Int           @id @default(autoincrement())
  doctorProfileId Int           @map("doctor_profile_id")
  dayOfWeek       Int           // 0 (Sunday) to 6 (Saturday)
  startTime       String        // e.g., "09:00"
  endTime         String        // e.g., "17:00"
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp(6)

  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("doctor_availabilities")
}

model DoctorLeave {
  id              Int           @id @default(autoincrement())
  doctorProfileId Int           @map("doctor_profile_id")
  startDate       String        // YYYY-MM-DD
  endDate         String        // YYYY-MM-DD
  reason          String?
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp(6)

  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("doctor_leaves")
}

model EmrRecord {
  id                Int      @id @default(autoincrement())
  patientId         Int      @map("patient_id")
  doctorId          Int      @map("doctor_id")
  appointmentId     Int?     @map("appointment_id")
  date              String   // YYYY-MM-DD
  
  // Vitals
  bloodPressure     String?  @map("blood_pressure")
  heartRate         Int?     @map("heart_rate")
  temperature       String?  @map("temperature")
  respiratoryRate   Int?     @map("respiratory_rate")
  weight            String?  @map("weight")
  height            String?  @map("height")
  bmi               String?  @map("bmi")
  oxygenSaturation  Int?     @map("oxygen_saturation")

  // Diagnosis
  diagnosis         String   // comma-separated list or JSON/text

  // SOAP Notes
  soapSubjective    String?  @map("soap_subjective")
  soapObjective     String?  @map("soap_objective")
  soapAssessment    String?  @map("soap_assessment")
  soapPlan          String?  @map("soap_plan")

  // Prescriptions
  prescriptions     String?  // Store as serialized JSON array of { medication, dosage, frequency, duration, instructions }

  // Follow-up Notes
  followUpNotes     String?  @map("follow_up_notes")
  followUpDate      String?  @map("follow_up_date") // YYYY-MM-DD

  // Attachments
  attachments       String?  // Store as serialized JSON array of { name, size, type, data } (base64 dataurl or url)

  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  doctor            User     @relation(fields: [doctorId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([patientId])
  @@index([doctorId])
  @@map("emr_records")
}

model Invoice {
  id             Int           @id @default(autoincrement())
  patientId      Int           @map("patient_id")
  doctorId       Int?          @map("doctor_id")
  invoiceNumber  String        @unique @map("invoice_number")
  date           String        // YYYY-MM-DD
  dueDate        String?       @map("due_date")
  status         String        @default("pending") // pending, paid, partially_paid, cancelled
  taxRate        Float         @default(0) @map("tax_rate") // e.g. 18.0 for 18% GST
  taxAmount      Float         @default(0) @map("tax_amount")
  discount       Float         @default(0) // discount amount
  subTotal       Float         @map("sub_total")
  totalAmount    Float         @map("total_amount")
  amountPaid     Float         @default(0) @map("amount_paid")
  paymentMethod  String?       @map("payment_method") // cash, card, upi
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  clinicId       Int?          @map("clinic_id")

  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  doctor         User?         @relation(fields: [doctorId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  clinic         Clinic?       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  items          InvoiceItem[]
  payments       Payment[]

  @@map("invoices")
}

model InvoiceItem {
  id          Int      @id @default(autoincrement())
  invoiceId   Int      @map("invoice_id")
  description String
  quantity    Int      @default(1)
  unitPrice   Float    @map("unit_price")
  totalPrice  Float    @map("total_price")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("invoice_items")
}

model Payment {
  id            Int      @id @default(autoincrement())
  invoiceId     Int      @map("invoice_id")
  amount        Float
  paymentDate   String   @map("payment_date") // YYYY-MM-DD
  paymentMethod String   @map("payment_method") // cash, card, upi
  referenceNo   String?  @map("reference_no") // e.g., transaction ID, UPI reference
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("payments")
}

model Medicine {
  id             Int                @id @default(autoincrement())
  name           String
  category       String             // e.g. Tablets, Syrup, Antibiotics
  code           String             @unique // e.g. MED-001
  stock          Int                @default(0)
  minStockAlert  Int                @default(10) @map("min_stock_alert")
  expiryDate     String             @map("expiry_date") // YYYY-MM-DD
  unitPrice      Float              @map("unit_price") // Selling price
  purchasePrice  Float              @map("purchase_price") // Buying price
  rackLocation   String?            @map("rack_location")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamp(6)
  clinicId       Int?               @map("clinic_id")
  purchases      MedicinePurchase[]
  sales          MedicineSale[]
  clinic         Clinic?            @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("medicines")
}

model MedicinePurchase {
  id           Int      @id @default(autoincrement())
  medicineId   Int      @map("medicine_id")
  quantity     Int
  supplier     String
  purchaseDate String   @map("purchase_date") // YYYY-MM-DD
  batchNumber  String   @map("batch_number")
  expiryDate   String   @map("expiry_date") // YYYY-MM-DD
  totalCost    Float    @map("total_cost")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  medicine     Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("medicine_purchases")
}

model MedicineSale {
  id            Int      @id @default(autoincrement())
  medicineId    Int      @map("medicine_id")
  quantity      Int
  patientId     Int?     @map("patient_id")
  saleDate      String   @map("sale_date") // YYYY-MM-DD
  totalPrice    Float    @map("total_price")
  paymentMethod String   @map("payment_method") // cash, card, upi
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  medicine      Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  patient       Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@map("medicine_sales")
}

model LabTest {
  id             Int        @id @default(autoincrement())
  name           String
  code           String     @unique // e.g. CBC-001
  category       String     // e.g. Hematology, Biochemistry, Immunology
  price          Float
  sampleType     String     @map("sample_type") // e.g. Blood, Urine
  turnaroundTime String     @map("turnaround_time") // e.g. 24 hours, 2 hours
  description    String?
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  orders         LabOrder[]

  @@map("lab_tests")
}

model LabOrder {
  id                  Int       @id @default(autoincrement())
  patientId           Int       @map("patient_id")
  testId              Int       @map("test_id")
  status              String    @default("BOOKED") // BOOKED, SAMPLE_COLLECTED, IN_PROGRESS, COMPLETED, CANCELLED
  bookingDate         String    @map("booking_date") // YYYY-MM-DD
  sampleCollectedAt   DateTime? @map("sample_collected_at")
  sampleBarcode       String?   @map("sample_barcode")
  sampleCollector     String?   @map("sample_collector")
  resultValue         String?   @map("result_value") // e.g. "14.2" or "Negative"
  normalRange         String?   @map("normal_range") // e.g. "12.0 - 16.0"
  unit                String?   // e.g. "g/dL"
  comments            String?
  reportAttachmentUrl String?   @map("report_attachment_url")
  validatedBy         String?   @map("validated_by") // Person who approved the result
  validatedAt         DateTime? @map("validated_at")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  clinicId            Int?      @map("clinic_id")

  patient             Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  test                LabTest   @relation(fields: [testId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  clinic              Clinic?   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("lab_orders")
}

model InventoryCategory {
  id          Int                @id @default(autoincrement())
  name        String             @unique
  description String?
  products    InventoryProduct[]

  @@map("inventory_categories")
}

model Vendor {
  id             Int             @id @default(autoincrement())
  name           String
  contactPerson  String?         @map("contact_person")
  email          String?
  phone          String?
  address        String?
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  purchaseOrders PurchaseOrder[]

  @@map("vendors")
}

model InventoryProduct {
  id            Int                 @id @default(autoincrement())
  name          String
  sku           String              @unique // Code
  barcode       String?             @unique
  categoryId    Int                 @map("category_id")
  unit          String              // e.g. Box, Piece, Vial
  stock         Int                 @default(0)
  minStockAlert Int                 @default(10) @map("min_stock_alert")
  description   String?
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  clinicId      Int?                @map("clinic_id")

  category      InventoryCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  movements     StockMovement[]
  poItems       PurchaseOrderItem[]
  clinic        Clinic?             @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("inventory_products")
}

model PurchaseOrder {
  id          Int                 @id @default(autoincrement())
  vendorId    Int                 @map("vendor_id")
  orderNumber String              @unique @map("order_number") // e.g. PO-2026-001
  status      String              @default("PENDING") // PENDING, ORDERED, RECEIVED, CANCELLED
  orderDate   String              @map("order_date") // YYYY-MM-DD
  totalAmount Float               @map("total_amount") @default(0.0)
  notes       String?
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamp(6)

  vendor      Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  items       PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              Int              @id @default(autoincrement())
  purchaseOrderId Int              @map("purchase_order_id")
  productId       Int              @map("product_id")
  quantity        Int
  unitCost        Float            @map("unit_cost")
  receivedQty     Int              @default(0) @map("received_qty")

  purchaseOrder   PurchaseOrder    @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product         InventoryProduct @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("purchase_order_items")
}

model StockMovement {
  id           Int              @id @default(autoincrement())
  productId    Int              @map("product_id")
  type         String           // IN, OUT
  quantity     Int
  batchNumber  String?          @map("batch_number")
  expiryDate   String?          @map("expiry_date") // YYYY-MM-DD
  reason       String           // e.g., "PURCHASE", "DISPENSED", "EXPIRED", "DAMAGED", "ADJUSTMENT"
  movementDate String           @map("movement_date") // YYYY-MM-DD
  notes        String?
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamp(6)

  product      InventoryProduct @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("stock_movements")
}

model QueueToken {
  id            Int         @id @default(autoincrement())
  tokenNumber   String      @map("token_number")
  patientId     Int         @map("patient_id")
  appointmentId Int?        @unique @map("appointment_id")
  doctorId      Int         @map("doctor_id")
  status        String      @default("WAITING") // WAITING, CALLING, IN_CONSULTATION, COMPLETED, SKIPPED
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  clinicId      Int?        @map("clinic_id")

  patient       Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  doctor        User        @relation(fields: [doctorId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  clinic        Clinic?     @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("queue_tokens")
}

model Notification {
  id              Int       @id @default(autoincrement())
  patientId       Int?      @map("patient_id")
  userId          Int?      @map("user_id")
  title           String
  message         String
  type            String    // APPOINTMENT_REMINDER, PRESCRIPTION_REMINDER, PAYMENT_REMINDER, GENERAL
  channel         String    // EMAIL, SMS, WHATSAPP, IN_APP, PUSH
  status          String    @default("SENT") // PENDING, SENT, DELIVERED, FAILED, READ
  deliveryDetails String?   @map("delivery_details")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  clinicId        Int?      @map("clinic_id")

  patient         Patient?  @relation(fields: [patientId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  clinic          Clinic?   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Clinic {
  id             Int                  @id @default(autoincrement())
  name           String
  slug           String               @unique
  email          String?
  phone          String?
  address        String?
  status         String               @default("active") // "active" | "suspended"
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamp(6)
  
  users          User[]
  patients       Patient[]
  appointments   Appointment[]
  invoices       Invoice[]
  medicines      Medicine[]
  labOrders      LabOrder[]
  inventoryProducts InventoryProduct[]
  queueTokens    QueueToken[]
  notifications  Notification[]
  subscriptions  ClinicSubscription[]
  billings       ClinicBilling[]
  usages         ClinicUsage[]
  customRoles    CustomRole[]
  auditLogs      AuditLog[]
  files          ClinicFile[]
  settings       ClinicSetting?
  tenantId       Int?                  @map("tenant_id")
  tenant         Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("clinics")
}

model ClinicSubscription {
  id           Int      @id @default(autoincrement())
  clinicId     Int      @map("clinic_id")
  planName     String   @map("plan_name") // "Free", "Starter", "Professional", "Enterprise"
  status       String   @default("active") // "active", "expired", "suspended"
  startDate    String   @map("start_date") // YYYY-MM-DD
  endDate      String   @map("end_date") // YYYY-MM-DD
  price        Float    @default(0)
  billingCycle String   @default("monthly") @map("billing_cycle") // "monthly" | "yearly"
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  
  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_subscriptions")
}

model ClinicBilling {
  id          Int      @id @default(autoincrement())
  clinicId    Int      @map("clinic_id")
  invoiceNo   String   @unique @map("invoice_no")
  amount      Float
  status      String   @default("unpaid") // "paid" | "unpaid" | "overdue"
  billingDate String   @map("billing_date") // YYYY-MM-DD
  dueDate     String   @map("due_date") // YYYY-MM-DD
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_billings")
}

model ClinicUsage {
  id                Int      @id @default(autoincrement())
  clinicId          Int      @unique @map("clinic_id")
  usersCount        Int      @default(0) @map("users_count")
  patientsCount     Int      @default(0) @map("patients_count")
  appointmentsCount Int      @default(0) @map("appointments_count")
  storageUsed       Float    @default(0.0) @map("storage_used") // MB
  lastUpdated       DateTime @default(now()) @updatedAt @map("last_updated") @db.Timestamp(6)
  
  clinic            Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_usages")
}

model CustomRole {
  id          Int                  @id @default(autoincrement())
  name        String
  description String?
  clinicId    Int?                 @map("clinic_id")
  isSystem    Boolean              @default(false) @map("is_system")
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamp(6)
  
  clinic      Clinic?              @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       User[]

  @@unique([name, clinicId])
  @@map("custom_roles")
}

model Permission {
  id          Int                  @id @default(autoincrement())
  code        String               @unique // e.g. "view_appointments", "manage_billing"
  name        String
  group       String               // e.g. "Appointments", "Billing"
  description String?
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamp(6)

  roles       RolePermission[]
  users       UserPermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamp(6)

  role         CustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  userId       Int        @map("user_id")
  permissionId Int        @map("permission_id")
  value        Boolean    @default(true) // true = grant, false = deny (override)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamp(6)

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  clinicId  Int?     @map("clinic_id")
  action    String   // e.g. "CREATE_APPOINTMENT"
  resource  String   // e.g. "appointment"
  details   String?  // JSON string or description
  ipAddress String?  @map("ip_address")
  device    String?
  browser   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  clinic    Clinic?  @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([clinicId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ClinicFile {
  id           Int          @id @default(autoincrement())
  name         String
  isFolder     Boolean      @default(false) @map("is_folder")
  parentId     Int?         @map("parent_id")
  fileType     String?      @map("file_type") // image, pdf, lab_report, prescription, patient_doc, insurance_doc, folder
  mimeType     String?      @map("mime_type")
  size         Int?         // size in bytes
  content      String?      @db.Text // base64 representation of file content for inline storage
  patientId    Int?         @map("patient_id")
  clinicId     Int?         @map("clinic_id")
  uploadedById Int?         @map("uploaded_by_id")
  accessRoles  String?      @map("access_roles") // e.g. "admin,doctor,reception,patient"
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  parent       ClinicFile?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children     ClinicFile[] @relation("FolderHierarchy")
  patient      Patient?     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic       Clinic?      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  uploadedBy   User?        @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([clinicId])
  @@index([patientId])
  @@index([parentId])
  @@map("clinic_files")
}

model ClinicSetting {
  id               Int      @id @default(autoincrement())
  clinicId         Int      @unique @map("clinic_id")
  hospitalName     String?  @map("hospital_name")
  hospitalCode     String?  @map("hospital_code")
  address          String?
  contactNumber    String?  @map("contact_number")
  website          String?
  departments      String?  @db.Text
  consultationFees Float    @default(50.0) @map("consultation_fees")
  slotDuration     Int      @default(15) @map("slot_duration")
  maxSlotsPerDay   Int      @default(30) @map("max_slots_per_day")
  workingHours     String?  @db.Text @map("working_hours")
  holidays         String?  @db.Text
  taxRate          Float    @default(0.0) @map("tax_rate")
  taxName          String?  @default("GST") @map("tax_name")
  currency         String   @default("USD")
  language         String   @default("en")
  emailHost        String?  @map("email_host")
  emailPort        Int?     @map("email_port")
  emailUser        String?  @map("email_user")
  emailPassword    String?  @map("email_password")
  emailFrom        String?  @map("email_from")
  emailEnabled     Boolean  @default(false) @map("email_enabled")
  smsGateway       String?  @map("sms_gateway")
  smsSid           String?  @map("sms_sid")
  smsToken         String?  @map("sms_token")
  smsFrom          String?  @map("sms_from")
  smsEnabled       Boolean  @default(false) @map("sms_enabled")
  waGateway        String?  @map("wa_gateway")
  waToken          String?  @map("wa_token")
  waNumber         String?  @map("wa_number")
  waEnabled        Boolean  @default(false) @map("wa_enabled")
  logoUrl          String?  @map("logo_url") @db.Text
  primaryColor     String?  @default("#0d9488") @map("primary_color")
  secondaryColor   String?  @default("#0f172a") @map("secondary_color")
  customDomain     String?  @map("custom_domain")
  emailSenderName  String?  @map("email_sender_name")
  emailFooter      String?  @map("email_footer") @db.Text
  pdfHeader        String?  @map("pdf_header") @db.Text
  pdfFooter        String?  @map("pdf_footer") @db.Text
  loginTitle       String?  @map("login_title")
  loginSubtitle    String?  @map("login_subtitle")
  loginBgUrl       String?  @map("login_bg_url") @db.Text
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  clinic           Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_settings")
}

model Tenant {
  id             Int                  @id @default(autoincrement())
  name           String
  slug           String               @unique
  status         String               @default("active") // "active" | "suspended"
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamp(6)

  clinics        Clinic[]
  users          User[]

  @@map("tenants")
}

model FeatureFlag {
  id              Int      @id @default(autoincrement())
  key             String   @unique
  name            String
  description     String?
  globallyEnabled Boolean  @default(true) @map("globally_enabled")
  plansEnabled    String   @default("Professional,Enterprise") @map("plans_enabled") // comma-separated list of plans
  tenantOverrides String   @default("{}") @map("tenant_overrides") // JSON string: {"clinicId": true/false}
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("feature_flags")
}

model AICdsProviderConfig {
  id              Int      @id @default(autoincrement())
  name            String   @unique // e.g. "Gemini", "OpenAI"
  modelName       String   @map("model_name") // e.g. "gemini-3.5-flash"
  apiKeyEnvVar    String   @default("GEMINI_API_KEY") @map("api_key_env_var")
  temperature     Float    @default(0.1)
  maxTokens       Int      @default(4000) @map("max_tokens")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("ai_cds_provider_configs")
}

model AICdsPromptTemplate {
  id              Int      @id @default(autoincrement())
  key             String   // e.g. "symptom_analysis", "differential_diagnosis", "drug_interactions"
  promptText      String   @db.Text @map("prompt_text")
  version         Int      @default(1)
  description     String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@unique([key, version])
  @@map("ai_cds_prompt_templates")
}

model AICdsAuditLog {
  id              Int      @id @default(autoincrement())
  provider        String
  model           String
  promptKey       String   @map("prompt_key")
  promptVersion   Int      @map("prompt_version")
  inputPayload    String   @db.Text @map("input_payload") // JSON representation of clinical context
  outputResponse  String   @db.Text @map("output_response") // JSON representation of model response
  status          String   // "SUCCESS" | "FAILURE"
  latencyMs       Int      @map("latency_ms")
  tokensUsed      Int?     @map("tokens_used")
  error           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([promptKey])
  @@index([createdAt])
  @@map("ai_cds_audit_logs")
}

model AICdsSuggestion {
  id                     Int       @id @default(autoincrement())
  patientId              Int       @map("patient_id")
  doctorId               Int       @map("doctor_id")
  appointmentId          Int?      @map("appointment_id")
  emrRecordId            Int?      @map("emr_record_id")
  symptomsText           String    @db.Text @map("symptoms_text")
  
  symptomAnalysis        String    @db.Text @map("symptom_analysis") // Stringified JSON
  differentialDiagnosis  String    @db.Text @map("differential_diagnosis") // Stringified JSON
  drugInteractions       String    @db.Text @map("drug_interactions") // Stringified JSON
  allergyWarnings        String    @db.Text @map("allergy_warnings") // Stringified JSON
  duplicateMedicines     String    @db.Text @map("duplicate_medicines") // Stringified JSON
  dosageSuggestions      String    @db.Text @map("dosage_suggestions") // Stringified JSON
  clinicalGuidelines     String    @db.Text @map("clinical_guidelines") // Stringified JSON
  riskScore              String    @db.Text @map("risk_score") // Stringified JSON
  explainability         String    @db.Text @map("explainability") // Stringified JSON
  
  isApproved             Boolean   @default(false) @map("is_approved")
  approvedBy             Int?      @map("approved_by")
  approvedAt             DateTime? @map("approved_at") @db.Timestamp(6)
  savedPrescription      String?   @db.Text @map("saved_prescription") // Stringified JSON
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  patient                Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor                 User      @relation("DoctorCds", fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([doctorId])
  @@map("ai_cds_suggestions")
}

model ImagingOrder {
  id           Int              @id @default(autoincrement())
  patientId    Int              @map("patient_id")
  doctorId     Int              @map("doctor_id")
  modality     String           // X-RAY, MRI, CT, ULTRASOUND, mammography, etc.
  bodyPart     String           @map("body_part") // Chest, Head, Lumbar Spine, etc.
  reason       String           @db.Text
  status       String           @default("REQUESTED") // REQUESTED, SCHEDULED, ACQUIRED, REPORTED, CANCELLED
  priority     String           @default("ROUTINE") // ROUTINE, URGENT, STAT
  orderDate    String           @map("order_date") // YYYY-MM-DD
  notes        String?          @db.Text
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  
  patient      Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor       User             @relation("DoctorImagingOrders", fields: [doctorId], references: [id], onDelete: Cascade)
  reports      RadiologyReport[]

  @@index([patientId])
  @@index([doctorId])
  @@map("imaging_orders")
}

model RadiologyReport {
  id             Int          @id @default(autoincrement())
  orderId        Int          @unique @map("order_id")
  patientId      Int          @map("patient_id")
  doctorId       Int          @map("doctor_id") // Doctor/Radiologist who wrote/reviewed
  findings       String       @db.Text
  impression     String       @db.Text
  recommendations String?     @db.Text
  status         String       @default("DRAFT") // DRAFT, SIGNED_OFF, APPROVED
  dicomImageUrl  String?      @map("dicom_image_url") // S3, local, or base64 mock URL
  dicomSeriesUid String?      @map("dicom_series_uid")
  dicomStudyUid  String?      @map("dicom_study_uid")
  signerName     String?      @map("signer_name")
  signedAt       DateTime?    @map("signed_at") @db.Timestamp(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamp(6)

  order          ImagingOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor         User         @relation("DoctorRadiologyReports", fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([doctorId])
  @@map("radiology_reports")
}







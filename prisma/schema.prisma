generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  uid           String         @unique(map: "users_uid_unique")
  email         String         @unique
  name          String
  password      String?
  role          String         @default("patient")
  refreshToken  String?        @map("refresh_token")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  appointments  Appointment[]
  doctorProfile DoctorProfile?
  emrRecords    EmrRecord[]

  @@map("users")
}

model Patient {
  id             Int           @id @default(autoincrement())
  name           String
  email          String
  phone          String
  dob            String
  gender         String
  bloodGroup     String?       @map("blood_group")
  address        String?
  medicalHistory String?       @map("medical_history")
  allergies      String?       @map("allergies")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  appointments   Appointment[]
  emrRecords     EmrRecord[]

  @@map("patients")
}

model Appointment {
  id        Int      @id @default(autoincrement())
  patientId Int      @map("patient_id")
  doctorId  Int      @map("doctor_id")
  date      String
  time      String
  status    String   @default("scheduled")
  reason    String
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  doctor    User     @relation(fields: [doctorId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "appointments_doctor_id_users_id_fk")
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "appointments_patient_id_patients_id_fk")

  @@map("appointments")
}

model DoctorProfile {
  id             Int                  @id @default(autoincrement())
  userId         Int                  @unique @map("user_id")
  specialization String
  biography      String?
  experienceYrs  Int                  @default(0) @map("experience_yrs")
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamp(6)
  
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  schedules      DoctorAvailability[]
  leaves         DoctorLeave[]

  @@map("doctor_profiles")
}

model DoctorAvailability {
  id              Int           @id @default(autoincrement())
  doctorProfileId Int           @map("doctor_profile_id")
  dayOfWeek       Int           // 0 (Sunday) to 6 (Saturday)
  startTime       String        // e.g., "09:00"
  endTime         String        // e.g., "17:00"
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp(6)

  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("doctor_availabilities")
}

model DoctorLeave {
  id              Int           @id @default(autoincrement())
  doctorProfileId Int           @map("doctor_profile_id")
  startDate       String        // YYYY-MM-DD
  endDate         String        // YYYY-MM-DD
  reason          String?
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp(6)

  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("doctor_leaves")
}

model EmrRecord {
  id                Int      @id @default(autoincrement())
  patientId         Int      @map("patient_id")
  doctorId          Int      @map("doctor_id")
  appointmentId     Int?     @map("appointment_id")
  date              String   // YYYY-MM-DD
  
  // Vitals
  bloodPressure     String?  @map("blood_pressure")
  heartRate         Int?     @map("heart_rate")
  temperature       String?  @map("temperature")
  respiratoryRate   Int?     @map("respiratory_rate")
  weight            String?  @map("weight")
  height            String?  @map("height")
  bmi               String?  @map("bmi")
  oxygenSaturation  Int?     @map("oxygen_saturation")

  // Diagnosis
  diagnosis         String   // comma-separated list or JSON/text

  // SOAP Notes
  soapSubjective    String?  @map("soap_subjective")
  soapObjective     String?  @map("soap_objective")
  soapAssessment    String?  @map("soap_assessment")
  soapPlan          String?  @map("soap_plan")

  // Prescriptions
  prescriptions     String?  // Store as serialized JSON array of { medication, dosage, frequency, duration, instructions }

  // Follow-up Notes
  followUpNotes     String?  @map("follow_up_notes")
  followUpDate      String?  @map("follow_up_date") // YYYY-MM-DD

  // Attachments
  attachments       String?  // Store as serialized JSON array of { name, size, type, data } (base64 dataurl or url)

  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  doctor            User     @relation(fields: [doctorId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("emr_records")
}

